# ==============================================
# BMS Project - Git Ignore Rules
# ==============================================

# -----------------------------------------------
# SERVER-MANAGED FILES (each environment owns its own)
# -----------------------------------------------
.htaccess

# -----------------------------------------------
# SENSITIVE: Database config (NEVER commit this!)
# -----------------------------------------------
includes/config.php

# -----------------------------------------------
# UPLOADS & USER-GENERATED CONTENT
# -----------------------------------------------
uploads/
documents/
downloads/

# -----------------------------------------------
# DATABASE BACKUPS & EXPORTS
# -----------------------------------------------
backups/
*.sql
*.sql.gz
*.sql.zip

# -----------------------------------------------
# LOG FILES
# -----------------------------------------------
*.log
api/debug_grn_log.txt

# -----------------------------------------------
# WINDOWS SYSTEM FILES
# -----------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------
# MACOS SYSTEM FILES
# -----------------------------------------------
.DS_Store
.AppleDouble

# -----------------------------------------------
# IDE & EDITOR FILES
# -----------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.qodo/

# -----------------------------------------------
# COMPOSER DEPENDENCIES (if used)
# -----------------------------------------------
vendor/
composer.lock

# -----------------------------------------------
# NODE MODULES (if any frontend tooling)
# -----------------------------------------------
node_modules/
package-lock.json
