# ==============================================
# BMS Project - Git Ignore Rules
# ==============================================

# -----------------------------------------------
# SENSITIVE: Database config (NEVER commit this!)
# -----------------------------------------------
includes/config.php

# -----------------------------------------------
# UPLOADS & USER-GENERATED CONTENT
# -----------------------------------------------
uploads/
documents/
downloads/

# -----------------------------------------------
# DATABASE BACKUPS & EXPORTS
# -----------------------------------------------
# Ignore everything under backups/ EXCEPT the .htaccess that locks the
# directory down. Without the !exception, the .htaccess would be hidden
# from git and lost on every fresh deploy, leaving .sql dumps publicly
# downloadable until someone manually recreated the file.
backups/*
!backups/.htaccess
*.sql
*.sql.gz
*.sql.zip

# -----------------------------------------------
# LOG FILES
# -----------------------------------------------
*.log
api/debug_grn_log.txt

# -----------------------------------------------
# WINDOWS SYSTEM FILES
# -----------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------
# MACOS SYSTEM FILES
# -----------------------------------------------
.DS_Store
.AppleDouble

# -----------------------------------------------
# IDE & EDITOR FILES
# -----------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.qodo/

# -----------------------------------------------
# COMPOSER DEPENDENCIES (if used)
# -----------------------------------------------
vendor/
composer.lock

# -----------------------------------------------
# NODE MODULES (if any frontend tooling)
# -----------------------------------------------
node_modules/
package-lock.json

# -----------------------------------------------
# SCRATCH / TEMP / TOOLING (local-only working dirs)
# Already-tracked files under these dirs remain tracked;
# this rule only stops NEW untracked files from being added.
# -----------------------------------------------
tmp/
scratch/
.claude/

# AI Assistant per-environment encryption secret (never commit)
includes/ai_app_secret.php
